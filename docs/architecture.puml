'================================================================
' Lua plugin
'================================================================
package "lua/cursortab (Neovim plugin)" as LuaPkg #FFFBE8 {

  class "init" as L_Init <<lua>> {
    + setup(user_config)
    + toggle()
    + accept() : boolean
    + is_completing() : boolean
    + on_completion_ready(diff)
    + on_cursor_prediction_ready(line)
    + on_reject()
    + show_log()
    + clear_log()
    + status()
    + restart()
    - _patch_completion_plugins()
  }

  class "config" as L_Config <<lua>> {
    - default_config : CursortabConfig
    - current_config : CursortabConfig
    - valid_provider_types
    - valid_log_levels
    - valid_addition_styles
    + get() : CursortabConfig
    + setup(user_config) : CursortabConfig
    + setup_highlights()
    - validate_config(cfg)
    - validate_config_keys(user, default, path)
    - migrate_deprecated_config(user)
  }

  class "CursortabConfig" as L_CTConfig <<lua>> {
    + enabled : boolean
    + log_level : string
    + state_dir : string
    + contribute_data : boolean
    + keymaps : KeymapsConfig
    + ui : UIConfig
    + behavior : BehaviorConfig
    + provider : ProviderConfig
    + blink : BlinkConfig
    + debug : DebugConfig
  }

  class "KeymapsConfig" as L_Keymaps <<lua>> {
    + accept : string|false
    + partial_accept : string|false
    + trigger : string|false
  }
  class "UIConfig" as L_UIConf <<lua>> {
    + completions.addition_style
    + completions.fg_opacity
    + jump.symbol
    + jump.text
    + jump.show_distance
  }
  class "BehaviorConfig" as L_Behav <<lua>> {
    + idle_completion_delay
    + text_change_debounce
    + max_visible_lines
    + cursor_prediction
    + disabled_in
    + ignore_paths
    + ignore_filetypes
    + ignore_gitignored
    + enabled_modes
  }
  class "ProviderConfig" as L_ProvCfg <<lua>> {
    + type : string
    + url : string
    + api_key_env : string
    + model : string
    + temperature : number
    + context_size : integer
    + max_tokens : integer
    + top_k : integer
    + completion_timeout : ms
    + max_diff_history_tokens
    + completion_path : string
    + fim_tokens : FIMTokens
    + privacy_mode : boolean
  }
  class "FIMTokens" as L_FIM <<lua>> {
    + prefix : string
    + suffix : string
    + middle : string
    + repo_name : string?
    + file_sep : string?
  }
  class "BlinkConfig" as L_BlinkCfg <<lua>> {
    + enabled : boolean
    + ghost_text : boolean
  }
  class "DebugConfig" as L_DebugCfg <<lua>> {
    + immediate_shutdown : boolean
  }

  class "buffer" as L_Buffer <<lua>> {
    - buffer_state : BufferState
    - gitignore_cache : map<string,bool>
    - gitignore_exceptions
    + update_state()
    + should_skip() : boolean
    + setup()
    - match_ignore_pattern(path,pat)
    - matches_ignore_paths(path,pats)
    - is_ignored_filetype(ft,list)
    - is_gitignored(path) : boolean
  }

  class "BufferState" as L_BufState <<lua>> {
    + is_floating_window : boolean
    + is_modifiable : boolean
    + is_readonly : boolean
    + filetype : string
    + should_skip : boolean
    + current_buf : integer
    + current_win : integer
  }

  class "events" as L_Events <<lua>> {
    - autocommands_setup_done : bool
    - current_keymaps
    - esc_handler_ns : integer?
    - skip_next_text_changed : bool
    - skip_next_cursor_moved : bool
    - awaiting_completion_after_jump : bool
    - text_changed_this_tick : bool
    - completing : bool
    - has_blink : bool
    + setup()
    + clear_all_completions()
    + clear_awaiting_completion()
    + accept() : boolean
    + is_completing() : boolean
    - on_accept() / on_partial_accept()
    - on_escape() / on_trigger()
    - update_keymap(name,key,handler,opts)
    - setup_keymaps()
    - suppress_blink() / release_blink()
    - dismiss_native_completion()
  }

  class "daemon" as L_Daemon <<lua>> {
    - chan : integer?
    - ns_id : integer
    - event_debounce_timer : integer?
    - is_enabled : boolean
    + send_event(name)
    + send_event_immediate(name)
    + send_reject()
    + force_start() : boolean
    + stop_daemon() : (bool,string)
    + set_enabled(b)
    + is_enabled() : boolean
    + get_namespace_id() : integer
    + check_daemon_status()
    + get_channel_status()
    - start_daemon() : boolean
    - send_rpc_event(name)
    - cleanup_stale_files()
    - is_process_running(pid)
    - read_daemon_pid(path)
  }

  class "ui" as L_UI <<lua>> {
    - has_completion : bool
    - has_cursor_prediction : bool
    - completion_extmarks : ExtmarkInfo[]
    - completion_windows : WindowInfo[]
    - dimmed_ns_cache : map
    - append_chars_state : AppendCharsState?
    - expected_line : string?
    - expected_line_num : integer?
    - original_len : integer?
    - append_chars_extmark_id : integer?
    - append_chars_buf : integer?
    - jump_text_extmark_id : integer?
    - jump_text_buf : integer?
    - absolute_jump_win/buf : integer?
    + show_completion(diff)
    + show_cursor_prediction(line)
    + close_all() / ensure_close_all()
    + has_completion() : bool
    + has_cursor_prediction() : bool
    + get_append_chars() : AppendCharsState?
    + typing_matches_completion(line,content)
    + update_ghost_text_for_typing(line,content)
    + create_scratch_window(title,content,opts)
    - create_overlay_window(...)
    - render_append_chars(...)
    - render_delete_chars(...)
    - render_replace_chars(...)
    - render_modification(...)
    - render_addition(...)
    - highlight_deletion(...)
    - blend_color(fg,bg,factor)
    - get_dimmed_ns(factor)
  }

  class "AppendCharsState" as L_Append <<lua>> {
    + text : string
    + line : integer
    + col_start : integer
  }
  class "DiffResult" as L_DiffRes <<lua>> {
    + groups : Group[]
    + startLine : integer
    + cursor_line : integer
    + cursor_col : integer
  }
  class "Group" as L_Group <<lua>> {
    + type : string
    + start_line / end_line
    + buffer_line
    + lines / old_lines
    + render_hint
    + col_start / col_end
  }

  class "treesitter" as L_TS <<lua>> {
    - scope_types
    - import_types
    + get_context(buf,row,col,max) : table?
    + cursor_scopes(buf,row,col) : string[]
  }

  class "health" as L_Health <<lua>> {
    + check()
  }

  class "blink" as L_Blink <<lua>> {
    - empty_response
    + new() : BlinkSource
    + enabled() : boolean
    + get_completions(ctx,cb)
  }
}

