'================================================================
' Cross-package wiring (high-level edges)
'================================================================

' RPC bridge — Lua talks to Go daemon over Neovim job RPC (stdio)
L_Daemon -[#B71C1C,thickness=2]-> G_Daemon : "rpcnotify\\n(cursortab_event)"
G_Daemon -[#B71C1C,thickness=2]-> L_Init   : "callback rpcnotify\\n(on_completion_ready,\\non_cursor_prediction_ready,\\non_reject)"

' main wires concrete implementations
G_Daemon ..> E_Engine     : owns
G_Daemon ..> B_Nvim       : owns
G_Daemon ..> P_Prov       : selects
G_Daemon ..> C_Gather     : creates
G_Daemon ..> C_Dataset    : dataset sender
G_Client --> G_Daemon     : spawns / connects

' Engine collaborators
E_Engine *-- C_Gather     : context gatherer
E_Engine ..> P_Prov       : provider chain
E_Engine ..> B_Nvim       : buffer ops
E_Engine ..> T_Staged     : staged completion

' Provider stack uses openai client + processors
P_Prov   ..> C_OpenAI     : default client
P_Prov   ..> Y_Req
P_Prov   ..> Y_Resp

' Eval harness drives the engine with FakeClock + Recorder
V_Cfg    ..> E_Engine     : runs against
V_Cfg    ..> P_Prov       : builds via factory
V_Rec    ..> P_Prov       : http transport
V_Rep    ..> P_Prov       : http transport

' Lua plugin sends request data eventually shaped into types.CompletionRequest server-side
L_Events ..> L_Daemon
L_Daemon ..> Y_Req        : via JSON over RPC
L_UI     ..> Y_Resp       : renders staged diff

