-- old.txt --
  if (!article) {
    return false;
  }

  if (article.tags === null) {
    article.tags = tag;
  } else {
    article.tags = concat(tag);
  }

  inc("tag_added");

  return true;
}
-- new.txt --
  if (!article) {
    return false;
  }

  article.tags.push(tag);

  inc("tag_added");

  return true;
}
